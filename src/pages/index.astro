---
import '../styles/global.css';
import { getPanels, getPanelCategories } from '../lib/db';
import { panelTabWrap, gridContent } from '../lib/html';

const panels       = getPanels();
const firstPanel   = panels[0] ?? null;
const firstPanelId = firstPanel?.id ?? null;
const initialCats  = firstPanel ? getPanelCategories(firstPanel.id) : [];
---
<!DOCTYPE html>
<html lang="en" data-theme="abyss">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/htmx.org@1.9.12/dist/htmx.min.js" defer></script>
  <script src="https://unpkg.com/alpinejs@3.14.3/dist/cdn.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js" defer></script>
</head>
<body x-data={`{ activePanel: ${firstPanelId ?? 'null'}, addingPanel: false, addingCategory: false, notesOpen: false }`}>

  <!-- ── Theme: apply saved preference before paint to avoid flash ── -->
  <script>
    (function () {
      var t = localStorage.getItem('dashboard-theme');
      if (t === 'cyberpunk' || t === 'abyss') document.documentElement.setAttribute('data-theme', t);
    })();
  </script>

  <!-- ── Topbar ──────────────────────────────────────────────── -->
  <div class="navbar bg-base-200 border-b border-base-300 min-h-0 px-8 py-2 text-xs tracking-widest uppercase font-semibold text-base-content/50">
    <div class="flex-1">OPS DASHBOARD &nbsp;&middot;&nbsp; <span id="greeting"></span></div>
    <div class="flex items-center gap-4">
      <label class="swap swap-rotate cursor-pointer" title="Toggle theme">
        <input type="checkbox" id="theme-checkbox" />
        <!-- sun icon → cyberpunk (light) -->
        <svg class="swap-on h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
        </svg>
        <!-- moon icon → abyss (dark) -->
        <svg class="swap-off h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z" />
        </svg>
      </label>
      <button
        @click="notesOpen = !notesOpen"
        class="btn btn-ghost btn-xs"
        title="Quick notes">
        <svg class="h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zm-7 14H7v-2h5v2zm5-4H7v-2h10v2zm0-4H7V7h10v2z"/>
        </svg>
      </button>
      <span id="clock"></span>
    </div>
  </div>

  <!-- ── Page header ─────────────────────────────────────────── -->
  <header class="flex items-end justify-between gap-8 px-8 py-6 border-b border-base-300 flex-wrap">

    <div>
      <h1 class="text-5xl font-bold tracking-tight uppercase leading-none">Daniel</h1>
      <p class="text-xs font-semibold tracking-widest uppercase text-base-content/50 mt-1.5">Link Dashboard</p>
    </div>

    <div class="flex flex-col items-end gap-2">

      <!-- Panel tabs + add panel -->
      <div class="flex items-center gap-1">
        <div role="tablist" class="tabs tabs-border" id="panel-tabs-inner">
          {panels.map(p => <Fragment set:html={panelTabWrap(p)} />)}
        </div>

        <div class="flex items-center gap-1">
          <button
            @click="addingPanel = !addingPanel"
            class="btn btn-outline btn-xs"
            x-text="addingPanel ? '×' : '+'"></button>

          <form
            x-show="addingPanel"
            x-cloak
            hx-post="/api/panels"
            hx-target="#panel-tabs-inner"
            hx-swap="beforeend"
            hx-on::after-request="if (event.detail.successful) { addingPanel = false; $el.reset(); }"
            class="flex items-center gap-1">
            <input
              name="name"
              placeholder="Panel name"
              required
              class="input input-xs input-bordered w-32"
              autocomplete="off">
            <button type="submit" class="btn btn-primary btn-xs">CREATE</button>
          </form>
        </div>
      </div>

      <!-- Add category (hidden until a panel exists) -->
      <div class="flex items-center gap-1" x-show="activePanel !== null">
        <button
          @click="addingCategory = !addingCategory"
          class="btn btn-outline btn-xs"
          x-text="addingCategory ? 'CANCEL' : '+ CATEGORY'"></button>

        <form
          x-show="addingCategory"
          x-cloak
          hx-post="/api/categories"
          hx-target="#categories-grid"
          hx-swap="beforeend"
          hx-on::after-request="if (event.detail.successful) { addingCategory = false; $el.reset(); }"
          class="flex items-center gap-1">
          <input type="hidden" name="panel_id" :value="activePanel">
          <input
            name="name"
            placeholder="Category name"
            required
            class="input input-xs input-bordered w-40"
            autocomplete="off">
          <button type="submit" class="btn btn-primary btn-xs">CREATE</button>
        </form>
      </div>

    </div>
  </header>

  <!-- ── Content ─────────────────────────────────────────────── -->
  <main class="px-8 pb-16">
    <div class="pt-4 pb-1">
      <input id="search-input" type="search"
        class="input input-sm border-0 border-b border-base-300 rounded-none bg-transparent w-56 focus:outline-none focus:border-base-content focus:w-80 transition-all placeholder:text-base-content/40"
        placeholder="Filter links…" autocomplete="off" spellcheck="false">
    </div>
    <div id="categories-grid">
      {panels.length === 0 ? (
        <div class="py-14 text-xs tracking-wide text-base-content/40">
          <p class="uppercase">No panels yet.</p>
          <small class="block mt-1 opacity-60">Click "+" above to create your first panel.</small>
        </div>
      ) : (
        <Fragment set:html={gridContent(initialCats)} />
      )}
    </div>
  </main>

  <!-- ── SortableJS drag-and-drop ───────────────────────────── -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {

      function saveLinksOrder(listEl) {
        const section = listEl.closest('[id^="category-"]');
        if (!section) return;
        const categoryId = Number(section.id.replace('category-', ''));
        const ids = Array.from(
          listEl.querySelectorAll(':scope > .link-item')
        ).map(el => Number(el.id.replace('link-', '')));
        fetch('/api/links/reorder', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ categoryId, ids }),
        });
      }

      let catSortable = null;
      const linkSortables = new Map();

      function initLinksList(listEl) {
        if (linkSortables.has(listEl)) linkSortables.get(listEl).destroy();
        const s = Sortable.create(listEl, {
          group:       'links',
          handle:      '.drag-handle',
          draggable:   '.link-item',
          animation:   130,
          ghostClass:  'drag-ghost',
          chosenClass: 'drag-chosen',
          onEnd(evt) {
            saveLinksOrder(evt.to);
            if (evt.from !== evt.to) saveLinksOrder(evt.from);
          },
        });
        linkSortables.set(listEl, s);
      }

      function initCategoriesSortable() {
        const grid = document.getElementById('categories-grid');
        if (!grid) return;
        if (catSortable) { catSortable.destroy(); catSortable = null; }
        catSortable = Sortable.create(grid, {
          handle:      '.cat-drag',
          draggable:   '.category-section',
          animation:   130,
          ghostClass:  'drag-ghost',
          chosenClass: 'drag-chosen',
          onEnd() {
            const ids = Array.from(
              grid.querySelectorAll(':scope > .category-section')
            ).map(el => Number(el.id.replace('category-', '')));
            fetch('/api/categories/reorder', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ids }),
            });
          },
        });
      }

      function initAll() {
        initCategoriesSortable();
        document.querySelectorAll('.links-list').forEach(initLinksList);
      }

      initAll();

      document.addEventListener('htmx:afterSettle', function (evt) {
        const t = evt.detail.target;
        if (!t) return;
        if (t.id === 'categories-grid' || t.closest?.('#categories-grid')) {
          initAll();
          const q = document.getElementById('search-input');
          if (window.filterLinks && q) window.filterLinks(q.value);
        }
      });
    });
  </script>

  <!-- ── Search / filter ────────────────────────────────────── -->
  <script>
    (function () {
      function filterLinks(q) {
        q = (q || '').trim().toLowerCase();
        document.querySelectorAll('.category-section').forEach(function (section) {
          var anyVisible = false;
          section.querySelectorAll('.link-item').forEach(function (item) {
            var name = (item.querySelector('.link-name') ?.textContent || '').toLowerCase();
            var sub  = (item.querySelector('.link-desc, .link-domain')?.textContent || '').toLowerCase();
            var show = !q || name.includes(q) || sub.includes(q);
            item.style.display = show ? '' : 'none';
            if (show) anyVisible = true;
          });
          section.style.display = (!q || anyVisible) ? '' : 'none';
        });
      }

      window.filterLinks = filterLinks;

      document.addEventListener('DOMContentLoaded', function () {
        var input = document.getElementById('search-input');
        if (!input) return;
        input.addEventListener('input', function () { filterLinks(this.value); });
        input.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') { this.value = ''; filterLinks(''); this.blur(); }
        });
      });
    })();
  </script>

  <!-- ── Panel keyboard shortcuts: 1–9 / focus search ─────── -->
  <script>
    document.addEventListener('keydown', function (evt) {
      var tag = document.activeElement && document.activeElement.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
      if (document.activeElement && document.activeElement.isContentEditable) return;
      if (evt.ctrlKey || evt.metaKey || evt.altKey) return;

      if (evt.key === '/') {
        var si = document.getElementById('search-input');
        if (si) { evt.preventDefault(); si.focus(); si.select(); }
        return;
      }

      var n = parseInt(evt.key, 10);
      if (n >= 1 && n <= 9) {
        var tabs = document.querySelectorAll('#panel-tabs-inner .tab');
        var tab  = tabs[n - 1];
        if (tab) tab.click();
      }
    });
  </script>

  <!-- ── Live clock + greeting ──────────────────────────────── -->
  <script>
    const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
    function greeting(h) {
      if (h >= 5  && h < 12) return 'Good morning';
      if (h >= 12 && h < 17) return 'Good afternoon';
      if (h >= 17 && h < 21) return 'Good evening';
      return 'Good night';
    }
    function tick() {
      const n = new Date();
      const d = `${MONTHS[n.getMonth()]} ${String(n.getDate()).padStart(2,'0')}, ${n.getFullYear()}`;
      const t = `${String(n.getHours()).padStart(2,'0')}:${String(n.getMinutes()).padStart(2,'0')}:${String(n.getSeconds()).padStart(2,'0')}`;
      const clock = document.getElementById('clock');
      if (clock) clock.textContent = `${d}  ${t}`;
      const greet = document.getElementById('greeting');
      if (greet) greet.textContent = greeting(n.getHours());
    }
    tick();
    setInterval(tick, 1000);
  </script>

  <!-- ── Quick notes drawer ─────────────────────────────────── -->
  <div
    x-show="notesOpen"
    x-cloak
    x-transition:enter="transition-transform duration-200 ease-out"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition-transform duration-150 ease-in"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed top-0 right-0 h-full w-80 bg-base-200 border-l border-base-300 shadow-2xl z-50 flex flex-col">
    <div class="flex items-center justify-between px-4 py-3 border-b border-base-300 shrink-0">
      <p class="text-xs font-bold tracking-widest uppercase">Quick Notes</p>
      <button @click="notesOpen = false" class="btn btn-ghost btn-xs">&times;</button>
    </div>
    <textarea
      id="notes-area"
      class="flex-1 w-full bg-transparent resize-none p-4 text-sm leading-relaxed focus:outline-none placeholder:text-base-content/30 font-mono"
      placeholder="Jot something down…"
      spellcheck="false"></textarea>
    <div class="px-4 py-2 border-t border-base-300 shrink-0 flex justify-end">
      <button
        id="notes-clear"
        class="btn btn-ghost btn-xs text-base-content/40 hover:text-error">CLEAR</button>
    </div>
  </div>

  <!-- ── Quick notes: persist to localStorage ───────────────── -->
  <script>
    (function () {
      var area  = document.getElementById('notes-area');
      var clear = document.getElementById('notes-clear');
      if (!area) return;
      area.value = localStorage.getItem('dashboard-notes') || '';
      area.addEventListener('input', function () {
        localStorage.setItem('dashboard-notes', this.value);
      });
      if (clear) clear.addEventListener('click', function () {
        area.value = '';
        localStorage.removeItem('dashboard-notes');
        area.focus();
      });
    })();
  </script>

  <!-- ── Theme toggle ────────────────────────────────────────── -->
  <script>
    (function () {
      var cb = document.getElementById('theme-checkbox');
      function applyTheme(t) {
        document.documentElement.setAttribute('data-theme', t);
        localStorage.setItem('dashboard-theme', t);
        if (cb) cb.checked = (t === 'cyberpunk');
      }
      // sync checkbox with current theme (may have been set by the inline script)
      var current = document.documentElement.getAttribute('data-theme') || 'abyss';
      if (cb) cb.checked = (current === 'cyberpunk');
      if (cb) cb.addEventListener('change', function () {
        applyTheme(this.checked ? 'cyberpunk' : 'abyss');
      });
    })();
  </script>

</body>
</html>
