---
import { getPanels, getPanelCategories } from '../lib/db';
import { panelTabWrap, gridContent } from '../lib/html';

const panels       = getPanels();
const firstPanel   = panels[0] ?? null;
const firstPanelId = firstPanel?.id ?? null;
const initialCats  = firstPanel ? getPanelCategories(firstPanel.id) : [];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/htmx.org@1.9.12/dist/htmx.min.js" defer></script>
  <script src="https://unpkg.com/alpinejs@3.14.3/dist/cdn.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js" defer></script>
  <!-- Theme: apply before first paint to prevent flash -->
  <script>
    (function () {
      var t = localStorage.getItem('theme') || 'system';
      document.documentElement.setAttribute('data-theme', t);
      var LABELS = { system: '\u25D0 AUTO', light: '\u25CB LIGHT', dark: '\u25CF DARK' };
      window.__themeLabels = LABELS;
      window.__themeOrder  = ['system', 'light', 'dark'];
      window.cycleTheme = function () {
        var order   = window.__themeOrder;
        var current = document.documentElement.getAttribute('data-theme') || 'system';
        var next    = order[(order.indexOf(current) + 1) % order.length];
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        var btn = document.getElementById('theme-btn');
        if (btn) btn.textContent = window.__themeLabels[next];
      };
      document.addEventListener('DOMContentLoaded', function () {
        var btn = document.getElementById('theme-btn');
        var theme = document.documentElement.getAttribute('data-theme') || 'system';
        if (btn) btn.textContent = window.__themeLabels[theme];
      });
    })();
  </script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    [x-cloak] { display: none !important; }

    :root {
      --bg:        #e9e5d8;
      --bg-hi:     #e2ddd0;
      --border:    #cac4b0;
      --border-lo: #d6d0bc;
      --text:      #141410;
      --text-sub:  #7a7568;
      --danger:    #891f1f;
      --mono:      'JetBrains Mono', ui-monospace, monospace;
      color-scheme: light;
    }

    /* ── Dark theme ─────────────────────────────────────────── */

    [data-theme="dark"] {
      --bg:        #1c1b18;
      --bg-hi:     #252420;
      --border:    #3d3b33;
      --border-lo: #2f2d27;
      --text:      #e8e4d8;
      --text-sub:  #6b6459;
      --danger:    #c44040;
      color-scheme: dark;
    }

    @media (prefers-color-scheme: dark) {
      [data-theme="system"] {
        --bg:        #1c1b18;
        --bg-hi:     #252420;
        --border:    #3d3b33;
        --border-lo: #2f2d27;
        --text:      #e8e4d8;
        --text-sub:  #6b6459;
        --danger:    #c44040;
        color-scheme: dark;
      }
    }

    html, body { height: 100%; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.45;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Topbar ─────────────────────────────────────────────── */

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.45rem 2rem;
      border-bottom: 1px solid var(--border);
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-sub);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    .theme-btn {
      background: none;
      border: none;
      color: var(--text-sub);
      cursor: pointer;
      font-family: var(--mono);
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0;
      transition: color 0.1s;
    }

    .theme-btn:hover { color: var(--text); }

    /* ── Page header ────────────────────────────────────────── */

    .page-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      padding: 1.5rem 2rem 1.25rem;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }

    .header-brand h1 {
      font-size: 3rem;
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1;
      color: var(--text);
      text-transform: uppercase;
    }

    .header-brand p {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-sub);
      margin-top: 0.35rem;
    }

    /* Right column: stacked controls */
    .header-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.6rem;
      padding-bottom: 0.1rem;
    }

    /* ── Panel tabs ─────────────────────────────────────────── */

    .panel-bar {
      display: flex;
      align-items: center;
      gap: 0.1rem;
    }

    .panel-tabs {
      display: flex;
      align-items: center;
    }

    .panel-tab-wrap {
      display: flex;
      align-items: center;
    }

    .panel-tab {
      background: none;
      border: none;
      color: var(--text-sub);
      padding: 0.3rem 0.75rem;
      cursor: pointer;
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      line-height: 1.4;
      transition: color 0.1s, background 0.1s;
      white-space: nowrap;
    }

    .panel-tab:hover:not(.active) { color: var(--text); }

    .panel-tab.active {
      background: var(--text);
      color: var(--bg);
    }

    /* × delete for panel tab */
    .panel-del {
      background: none;
      border: none;
      color: var(--text-sub);
      cursor: pointer;
      font-family: var(--mono);
      font-size: 0.65rem;
      padding: 0.2rem 0.3rem;
      opacity: 0;
      transition: opacity 0.1s, color 0.1s;
      line-height: 1;
      margin-right: 0.15rem;
    }

    .panel-tab-wrap:hover .panel-del { opacity: 0.45; }
    .panel-tab.active ~ .panel-del   { opacity: 0.3; }
    .panel-del:hover                  { opacity: 1 !important; color: var(--danger); }

    /* + new panel button */
    .add-panel-btn {
      background: none;
      border: 1px solid var(--border);
      color: var(--text-sub);
      padding: 0.25rem 0.55rem;
      cursor: pointer;
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 600;
      line-height: 1.3;
      transition: color 0.1s, border-color 0.1s;
      margin-left: 0.3rem;
    }

    .add-panel-btn:hover { color: var(--text); border-color: var(--text-sub); }

    .add-panel-ctrl {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .add-panel-form {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    /* ── Add-category row ───────────────────────────────────── */

    .add-cat-ctrl {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .add-cat-form {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    /* ── Main content ───────────────────────────────────────── */

    main {
      padding: 0 2rem 4rem;
    }

    #categories-grid {
      /* block flow — no CSS grid */
    }

    /* ── Search bar ─────────────────────────────────────────── */

    .search-bar {
      padding: 0.9rem 2rem 0;
      display: flex;
      align-items: center;
    }

    .search-input {
      -webkit-appearance: none;
      appearance: none;
      background: var(--bg);
      border: none;
      border-bottom: 1px solid var(--border-lo);
      color: var(--text);
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      padding: 0.18rem 0 0.18rem 0;
      width: 220px;
      outline: none;
      transition: border-color 0.15s, width 0.2s;
      -webkit-appearance: none;
    }

    .search-input:focus {
      border-bottom-color: var(--text);
      width: 320px;
    }

    .search-input::placeholder { color: var(--text-sub); }
    .search-input::-webkit-search-cancel-button { display: none; }

    /* ── Category section ───────────────────────────────────── */

    .category-section {
      padding-top: 1.5rem;
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding-bottom: 0.5rem;
      margin-bottom: 0;
    }

    .category-name {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text);
      white-space: nowrap;
      flex-shrink: 0;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      font-family: var(--mono);
    }

    .category-name:hover { opacity: 0.7; }

    /* ── Rename modal ────────────────────────────────────────── */

    .rename-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 200;
    }

    .rename-dialog {
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      min-width: 320px;
    }

    .rename-label {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-sub);
    }

    .rename-form {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    /* The —————— fill between name and buttons */
    .cat-rule {
      flex: 1;
      height: 1px;
      background: var(--border);
      display: block;
    }

    .category-actions {
      display: flex;
      gap: 0.3rem;
      flex-shrink: 0;
    }

    /* ── Links list ─────────────────────────────────────────── */

    .links-list {
      list-style: none;
      padding: 0;
    }

    .link-item {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      padding: 0.55rem 0;
    }

    .drag-handle {
      font-size: 0.9rem;
      color: var(--text-sub);
      opacity: 0.4;
      cursor: default;
      user-select: none;
      flex-shrink: 0;
      margin-top: 0.05rem;
      line-height: 1;
    }

    .link-body {
      flex: 1;
      min-width: 0;
    }

    .link-name {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      line-height: 1.3;
    }

    .link-name:hover {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .link-domain {
      display: block;
      font-size: 0.63rem;
      color: var(--text-sub);
      margin-top: 0.18rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .link-desc {
      display: block;
      font-size: 0.63rem;
      color: var(--text-sub);
      margin-top: 0.18rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .link-actions {
      display: flex;
      gap: 0.25rem;
      opacity: 0;
      transition: opacity 0.1s;
      flex-shrink: 0;
      padding-top: 0.05rem;
    }

    .link-item:hover .link-actions { opacity: 1; }

    /* ── Edit form ──────────────────────────────────────────── */

    .link-editing {
    }

    .link-editing .drag-handle { margin-top: 0.35rem; }

    .edit-form {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      flex: 1;
      flex-wrap: wrap;
    }

    .edit-form .form-input:first-of-type { flex: 1; min-width: 80px; }
    .edit-form .url-input               { flex: 2; min-width: 120px; }
    .edit-form .desc-input              { flex: 2; min-width: 120px; }

    /* ── Add link modal ─────────────────────────────────────── */

    .add-link-modal {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 200;
    }

    .add-link-dialog {
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      min-width: 380px;
    }

    .dialog-title {
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 0.25rem;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .field-label {
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-sub);
    }

    .dialog-actions {
      display: flex;
      justify-content: flex-end;
      gap: 0.4rem;
      margin-top: 0.25rem;
    }

    .form-select {
      -webkit-appearance: none;
      appearance: none;
      background: var(--bg);
      border: none;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      padding: 0.25rem 0.3rem;
      font-size: 0.75rem;
      font-family: var(--mono);
      font-weight: 500;
      letter-spacing: 0.04em;
      outline: none;
      cursor: pointer;
      flex: 1.5;
      min-width: 80px;
      transition: border-color 0.12s;
    }

    .form-select:focus { border-bottom-color: var(--text); }

    /* ── Buttons ────────────────────────────────────────────── */

    .btn {
      -webkit-appearance: none;
      appearance: none;
      background: transparent;
      border: 1px solid transparent;
      color: var(--text-sub);
      padding: 0.2rem 0.5rem;
      cursor: pointer;
      font-size: 0.62rem;
      font-family: var(--mono);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 1.4;
      transition: color 0.1s, border-color 0.1s;
      white-space: nowrap;
    }

    .btn:hover {
      color: var(--text);
      border-color: var(--border);
    }

    .btn-primary {
      background: var(--text);
      border-color: var(--text);
      color: var(--bg);
    }

    .btn-primary:hover { opacity: 0.8; }

    .btn-danger { color: var(--danger); }
    .btn-danger:hover { border-color: var(--danger); }

    /* ── Inputs ─────────────────────────────────────────────── */

    .form-input {
      -webkit-appearance: none;
      appearance: none;
      background: var(--bg);
      border: none;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      padding: 0.25rem 0.3rem;
      font-size: 0.75rem;
      font-family: var(--mono);
      font-weight: 500;
      letter-spacing: 0.04em;
      outline: none;
      transition: border-color 0.12s;
      width: 100%;
    }

    .form-input::placeholder { color: var(--text-sub); }
    .form-input:focus        { border-bottom-color: var(--text); }

    /* Kill browser autofill white/yellow flash */
    .form-input:-webkit-autofill,
    .form-input:-webkit-autofill:hover,
    .form-input:-webkit-autofill:focus {
      -webkit-box-shadow: 0 0 0 1000px var(--bg) inset;
      -webkit-text-fill-color: var(--text);
      caret-color: var(--text);
    }

    /* ── Drag & drop ────────────────────────────────────────── */

    /* Handles */
    .cat-drag,
    .drag-handle {
      cursor: grab;
    }
    .cat-drag:active,
    .drag-handle:active {
      cursor: grabbing;
    }
    /* Style the cat-drag to match the existing drag-handle look */
    .cat-drag {
      font-size: 0.9rem;
      color: var(--text-sub);
      opacity: 0.4;
      user-select: none;
      flex-shrink: 0;
      line-height: 1;
      transition: opacity 0.1s;
    }
    .category-header:hover .cat-drag { opacity: 0.75; }

    /* Ghost = the placeholder that marks the drop target */
    .drag-ghost {
      opacity: 0.25 !important;
      background: var(--bg-hi) !important;
    }
    /* While dragging, hide edit/action buttons on the ghost */
    .drag-ghost .link-actions,
    .drag-ghost .category-actions { opacity: 0 !important; }

    /* The element currently being dragged (floating clone) */
    .drag-chosen { opacity: 0.9; }

    /* ── Empty states ───────────────────────────────────────── */

    .empty-state,
    .no-panels {
      padding: 3.5rem 0;
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      color: var(--text-sub);
    }

    .empty-state p, .no-panels p {
      text-transform: uppercase;
    }

    .empty-state small, .no-panels small {
      display: block;
      margin-top: 0.4rem;
      font-size: 0.62rem;
      opacity: 0.55;
    }
  </style>
</head>
<body x-data={`{ activePanel: ${firstPanelId ?? 'null'}, addingPanel: false, addingCategory: false }`}>

  <!-- ── Topbar: label + theme toggle + live clock ──────────── -->
  <div class="topbar">
    <span>OPS DASHBOARD &nbsp;&middot;&nbsp; <span id="greeting"></span></span>
    <span class="topbar-right">
      <button id="theme-btn" class="theme-btn" onclick="cycleTheme()">&#x25D0; AUTO</button>
      <span id="clock"></span>
    </span>
  </div>

  <!-- ── Page header: branding + panel controls ─────────────── -->
  <header class="page-header">

    <div class="header-brand">
      <h1>Command</h1>
      <p>Mission Control</p>
    </div>

    <div class="header-right">

      <!-- Panel tabs + add panel -->
      <div class="panel-bar">
        <nav id="panel-tabs-inner" class="panel-tabs">
          {panels.map(p => <Fragment set:html={panelTabWrap(p)} />)}
        </nav>

        <div class="add-panel-ctrl">
          <button
            @click="addingPanel = !addingPanel"
            class="add-panel-btn"
            x-text="addingPanel ? '×' : '+'"></button>

          <form
            x-show="addingPanel"
            x-cloak
            hx-post="/api/panels"
            hx-target="#panel-tabs-inner"
            hx-swap="beforeend"
            hx-on::after-request="if (event.detail.successful) { addingPanel = false; $el.reset(); }"
            class="add-panel-form">
            <input
              name="name"
              placeholder="Panel name"
              required
              class="form-input"
              autocomplete="off"
              style="width: 130px;">
            <button type="submit" class="btn btn-primary">CREATE</button>
          </form>
        </div>
      </div>

      <!-- Add category (hidden until a panel exists) -->
      <div class="add-cat-ctrl" x-show="activePanel !== null">
        <button
          @click="addingCategory = !addingCategory"
          class="btn"
          x-text="addingCategory ? 'CANCEL' : '+ CATEGORY'"></button>

        <form
          x-show="addingCategory"
          x-cloak
          hx-post="/api/categories"
          hx-target="#categories-grid"
          hx-swap="beforeend"
          hx-on::after-request="if (event.detail.successful) { addingCategory = false; $el.reset(); }"
          class="add-cat-form">
          <input type="hidden" name="panel_id" :value="activePanel">
          <input
            name="name"
            placeholder="Category name"
            required
            class="form-input"
            autocomplete="off"
            style="width: 160px;">
          <button type="submit" class="btn btn-primary">CREATE</button>
        </form>
      </div>

    </div>
  </header>

  <!-- ── Category list ──────────────────────────────────────── -->
  <main>
    <div class="search-bar">
      <input id="search-input" type="search" class="search-input"
        placeholder="Filter links…" autocomplete="off" spellcheck="false">
    </div>
    <div id="categories-grid">
      {panels.length === 0 ? (
        <div class="no-panels">
          <p>No panels yet.</p>
          <small>Click &ldquo;+&rdquo; above to create your first panel.</small>
        </div>
      ) : (
        <Fragment set:html={gridContent(initialCats)} />
      )}
    </div>
  </main>

  <!-- ── SortableJS drag-and-drop ───────────────────────── -->
  <script>
    // All defer scripts (HTMX, Alpine, SortableJS) execute before
    // DOMContentLoaded, so Sortable is guaranteed to exist by the time
    // this listener fires.
    document.addEventListener('DOMContentLoaded', function () {

      // ── Helpers ──────────────────────────────────────────────

      /** Read current order from a links list and persist it. */
      function saveLinksOrder(listEl) {
        const section = listEl.closest('[id^="category-"]');
        if (!section) return;
        const categoryId = Number(section.id.replace('category-', ''));
        const ids = Array.from(
          listEl.querySelectorAll(':scope > .link-item')
        ).map(el => Number(el.id.replace('link-', '')));
        fetch('/api/links/reorder', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ categoryId, ids }),
        });
      }

      // ── State ────────────────────────────────────────────────

      let catSortable = null;
      // Map<HTMLElement, Sortable> — keyed by the actual DOM node
      const linkSortables = new Map();

      // ── Init helpers ─────────────────────────────────────────

      function initLinksList(listEl) {
        if (linkSortables.has(listEl)) linkSortables.get(listEl).destroy();
        const s = Sortable.create(listEl, {
          group:       'links',       // shared group = cross-category drag
          handle:      '.drag-handle',
          draggable:   '.link-item',
          animation:   130,
          ghostClass:  'drag-ghost',
          chosenClass: 'drag-chosen',
          onEnd(evt) {
            saveLinksOrder(evt.to);
            if (evt.from !== evt.to) saveLinksOrder(evt.from);
          },
        });
        linkSortables.set(listEl, s);
      }

      function initCategoriesSortable() {
        const grid = document.getElementById('categories-grid');
        if (!grid) return;
        if (catSortable) { catSortable.destroy(); catSortable = null; }
        catSortable = Sortable.create(grid, {
          handle:      '.cat-drag',
          draggable:   '.category-section',
          animation:   130,
          ghostClass:  'drag-ghost',
          chosenClass: 'drag-chosen',
          onEnd() {
            const ids = Array.from(
              grid.querySelectorAll(':scope > .category-section')
            ).map(el => Number(el.id.replace('category-', '')));
            fetch('/api/categories/reorder', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ids }),
            });
          },
        });
      }

      function initAll() {
        initCategoriesSortable();
        document.querySelectorAll('.links-list').forEach(initLinksList);
      }

      // ── Boot ─────────────────────────────────────────────────

      initAll();

      // Re-init whenever HTMX updates something inside the categories grid.
      // Covers: panel switch, new category, new link, link delete.
      document.addEventListener('htmx:afterSettle', function (evt) {
        const t = evt.detail.target;
        if (!t) return;
        if (t.id === 'categories-grid' || t.closest?.('#categories-grid')) {
          initAll();
          const q = document.getElementById('search-input');
          if (window.filterLinks && q) window.filterLinks(q.value);
        }
      });
    });
  </script>

  <!-- Search / filter -->
  <script>
    (function () {
      function filterLinks(q) {
        q = (q || '').trim().toLowerCase();
        document.querySelectorAll('.category-section').forEach(function (section) {
          var anyVisible = false;
          section.querySelectorAll('.link-item').forEach(function (item) {
            var name = (item.querySelector('.link-name') ?.textContent || '').toLowerCase();
            var sub  = (item.querySelector('.link-desc, .link-domain')?.textContent || '').toLowerCase();
            var show = !q || name.includes(q) || sub.includes(q);
            item.style.display = show ? '' : 'none';
            if (show) anyVisible = true;
          });
          section.style.display = (!q || anyVisible) ? '' : 'none';
        });
      }

      window.filterLinks = filterLinks;

      document.addEventListener('DOMContentLoaded', function () {
        var input = document.getElementById('search-input');
        if (!input) return;
        input.addEventListener('input', function () { filterLinks(this.value); });
        input.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') { this.value = ''; filterLinks(''); this.blur(); }
        });
      });
    })();
  </script>

  <!-- Panel keyboard shortcuts: 1–9  /  focus search -->
  <script>
    document.addEventListener('keydown', function (evt) {
      // Skip when focus is inside any form field
      var tag = document.activeElement && document.activeElement.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
      if (document.activeElement && document.activeElement.isContentEditable) return;
      if (evt.ctrlKey || evt.metaKey || evt.altKey) return;

      // / → focus search input
      if (evt.key === '/') {
        var si = document.getElementById('search-input');
        if (si) { evt.preventDefault(); si.focus(); si.select(); }
        return;
      }

      // 1–9 → switch panel
      var n = parseInt(evt.key, 10);
      if (n >= 1 && n <= 9) {
        var tabs = document.querySelectorAll('#panel-tabs-inner .panel-tab');
        var tab  = tabs[n - 1];
        if (tab) tab.click();
      }
    });
  </script>

  <!-- Live clock + greeting -->
  <script>
    const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
    function greeting(h) {
      if (h >= 5  && h < 12) return 'Good morning';
      if (h >= 12 && h < 17) return 'Good afternoon';
      if (h >= 17 && h < 21) return 'Good evening';
      return 'Good night';
    }
    function tick() {
      const n = new Date();
      const d = `${MONTHS[n.getMonth()]} ${String(n.getDate()).padStart(2,'0')}, ${n.getFullYear()}`;
      const t = `${String(n.getHours()).padStart(2,'0')}:${String(n.getMinutes()).padStart(2,'0')}:${String(n.getSeconds()).padStart(2,'0')}`;
      const clock = document.getElementById('clock');
      if (clock) clock.textContent = `${d}  ${t}`;
      const greet = document.getElementById('greeting');
      if (greet) greet.textContent = greeting(n.getHours());
    }
    tick();
    setInterval(tick, 1000);
  </script>

</body>
</html>
